alias sudo='sudo-rs'

# Use neovim for vim if present
[ -x "$(command -v nvim)" ] && alias vim=nvim vimdiff="nvim -d"

# [ -f "$MBSYNCRC" ] && alias mbsync="mbsync -c $MBSYNCRC"
alias mbsync='mbsync -c "$XDG_CONFIG_HOME"/isync/mbsyncrc'

#sudo not required for some system commands
for command in mount umount sv pacman updatedb su shutdown poweroff reboot; do
    alias $command="sudo-rs $command"
done

# Arch
alias \
    orphaned='sudo-rs pacman -Rns $(pacman -Qtdq)' \
    fixpac='sudo uu-rm /var/lib/pacman/db.lck' \
    upd="sudo-rs reflector --verbose --threads 8 --country 'US,CA' --protocol https --sort rate --save /etc/pacman.d/mirrorlist && doas pacman -Syu"

# Pacman - https://wiki.archlinux.org/index.php/Pacman_Tips

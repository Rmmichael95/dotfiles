alias cl='clear'

# XDG
alias startx='startx "$XDG_CONFIG_HOME/x11/xinitrc"'
alias nvidia-settings='nvidia-settings --config="$XDG_CONFIG_HOME"/nvidia/settings'

alias \
    dls='fd -d 1 -t f --hidden . ~/documents/.bc/batcave/dotfiles/ | fzf | xargs -I{} nvim {}' \
    cls='fd -t f --hidden . ~/documents/.bc/batcave/dotfiles/.config/ | fzf | xargs -I{} nvim {}' \
    sls='fd -t f . ~/documents/.bc/batcave/dotfiles/.local/myBin/ | fzf | xargs -I{} nvim {}' \
    wpt='fd -d 1 -t d . ~/Local\ Sites/**/app/public/wp-content/themes/ | fzf | xargs -I{} z {}' \
    rsd='systemctl --no-legend --type=service --state=running | fzf | awk '\''{print $1}'\'' | xargs sudo systemctl restart'


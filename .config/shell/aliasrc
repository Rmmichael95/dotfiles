# ls='ls -hN --color=auto --group-directories-first' \
# Colorize commands when possible.
alias \
    grep='grep --color=auto' \
    diff='diff --color=auto' \
    ccat='highlight --out-format=ansi' \
    ip='ip -color=auto'

# TODO update to rg
#alias sgrep='grep -R -n -H -C 5 --exclude-dir={.git,.svn,CVS} '

# Verbosity and settings that you pretty much just always are going to want.
alias \
    ..='z ..' \
    ...='z ../..' \
    ....='z ../../..' \
    .....='z ../../../..' \
    ......='z ../../../../..' \
    cd='z' \
    cp='uu-cp -iv' \
    mv='uu-mv -iv' \
    rm='uu-rm -vI' \
    bc='bc -ql' \
    rsync='rsync -vrPlu' \
    mkd='uu-mkdir -pv' \
    yt='yt-dlp --embed-metadata -i' \
    yta='yt -x -f bestaudio/best' \
    ytt='yt --skip-download --write-thumbnail' \
    ffmpeg='ffmpeg -hide_banner' \
    dir='uu-dir --color=auto' \
    vdir='vdir --color=auto' \
    path='echo -e ${PATH//:/\\n}' \
    ugtar='tar -zxvf ' \
    untar='tar -zxvf ' \
    wget='wget -c --hsts-file="$XDG_CACHE_HOME/wget-hsts" '

alias \
    h='history' \
    hl='history | less' \
    hs='history | grep' \
    his='history | grep -i'

# eza
#
#size,show type,human readable
#long list,show almost all,show type,human readable
#sorted by date,recursive,show type,human readable
#long list,sorted by date,show type,human readable
#Recursive list of files and directories
#
#A column contains name of files and directories
#long list
alias \
    l='eza --group-directories-first auto' \
    ls='eza --group-directories-first -lhF auto' \
    la='eza --group-directories-first -lAhF auto' \
    lr='eza --group-directories-first -tRhF' \
    lt='eza --group-directories-first -lthF' \
    ll='eza --group-directories-first -l' \
    ldot='eza --group-directories-first -ld .*' \
    lS='eza --group-directories-first -1SshF' \
    lart='eza --group-directories-first -1cartF' \
    lrt='eza --group-directories-first -1crtF' \
    lsr='eza --group-directories-first -lARhF auto' \
    lsn='eza --group-directories-first -1'

# These common commands are just too long! Abbreviate them.
